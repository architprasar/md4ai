{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "paths": {
      "@architprasar/md4ai": ["../../src/index.ts"],
      "@architprasar/md4ai/core": ["../../src/core.ts"],
      "@architprasar/md4ai/react": ["../../src/react.ts"]
    }
  },
  "include": ["src"]
}
